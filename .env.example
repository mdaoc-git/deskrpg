# .env.example — copy to .env.local and fill in values
DATABASE_URL=postgresql://deskrpg:deskrpg_dev_pw@localhost:5437/deskrpg
JWT_SECRET=change-me-to-a-random-64-char-string
DESKRPG_IMAGE=dandacompany/deskrpg:latest
OPENCLAW_IMAGE=deskrpg-openclaw:latest
OPENCLAW_TOKEN=change-me-openclaw-token
OPENCLAW_MODEL=openai-codex/gpt-5.4

# Cookie security: set to "true" for HTTPS deployments, "false" for HTTP/localhost
# COOKIE_SECURE=false

# Optional: Disable public registration (invite-only mode)
# REGISTRATION_DISABLED=true
# NEXT_PUBLIC_REGISTRATION_DISABLED=true

# Optional: SQLite mode (no PostgreSQL needed)
# DB_TYPE=sqlite
# SQLITE_PATH=data/deskrpg.db
